<?xml version="1.0" encoding="UTF-8"?>
<!--
  ATCS-GH | Achimota/Neoplan Junction — Morning Rush Hour Demand
  ══════════════════════════════════════════════════════════════
  Real-world calibration: Achimota/Neoplan Junction, N6 Nsawam Road, Accra
  GPS: 5.6216 N, 0.2193 W

  Simulates 07:00-09:00 AM (7200 seconds) — peak morning commute.

  Traffic Pattern (Achimota-realistic):
  ┌──────────────────┬────────────┬──────────────────────────────────────────┐
  │ Route            │ veh/hr     │ Rationale                                │
  ├──────────────────┼────────────┼──────────────────────────────────────────┤
  │ N → S (Nsawam→CBD) │  900     │ Heavy inbound commute on N6 trunk road   │
  │ S → N (CBD→Nsawam) │  300     │ Light reverse flow                       │
  │ E → W (Aggrey St)  │  350     │ Secondary road moderate flow             │
  │ W → E (Guggisberg)  │  100     │ Minor residential street, low volume     │
  │ W → N              │  150      │ Guggisberg feeding onto N6 northbound    │
  │ (turns)            │  90-200   │ Mixed turning traffic                    │
  └──────────────────┴────────────┴──────────────────────────────────────────┘

  Vehicle mix: ~85% cars (Toyota Corolla, Kia Rio), ~10% trotros, ~5% other
  Trotros are prevalent on Achimota Forest Rd and Aggrey St.

  Emergency Vehicle Scenarios:
    ambulance_1 — departs North  t=130s  (Achimota Forest Rd from Nsawam)
    ambulance_2 — departs West   t=700s  (Guggisberg St)
    ambulance_3 — departs South  t=1800s (Achimota Forest Rd from CBD)
-->
<routes>

  <!-- ═══════════════════════════════════════════════════════════════
       VEHICLE TYPES
  ═══════════════════════════════════════════════════════════════ -->

  <!-- Standard passenger car (Toyota Corolla / Kia Rio — common in Accra) -->
  <vType id="car"
         accel="2.6"
         decel="4.5"
         emergencyDecel="9.0"
         sigma="0.5"
         length="4.5"
         minGap="2.5"
         maxSpeed="13.89"
         guiShape="passenger"
         color="0.6,0.6,0.9"
         jmCrossingGap="3.0"/>

  <!-- Trotro (shared minibus) — extremely common in Accra, slower + longer -->
  <vType id="trotro"
         accel="1.8"
         decel="3.5"
         emergencyDecel="7.0"
         sigma="0.7"
         length="7.0"
         minGap="3.0"
         maxSpeed="11.11"
         guiShape="bus/city"
         color="1.0,0.8,0.0"
         jmCrossingGap="3.0"/>

  <!-- Pedestrian — faster walking speed (Ghanaian crossing behavior) -->
  <vType id="ped_fast" vClass="pedestrian"
         speed="3.80"
         length="0.25" minGap="0.5" width="0.65"/>

  <!-- Emergency vehicle (ambulance) — vClass gives blue-light privileges -->
  <vType id="emergency" vClass="emergency"
         accel="3.5"
         decel="6.0"
         emergencyDecel="9.0"
         sigma="0.0"
         tau="0.5"
         length="5.5"
         minGap="1.5"
         maxSpeed="16.67"
         guiShape="emergency"
         color="1.0,0.0,0.0"
         speedFactor="1.2"
         lcStrategic="100" lcPushy="1.0" lcAssertive="1.0"
         jmDriveAfterRedTime="3" jmDriveAfterYellowTime="3"/>


  <!-- ═══════════════════════════════════════════════════════════════
       ROUTES
       Vehicles travel: [incoming edge] → junction J0 → [outgoing edge]
  ═══════════════════════════════════════════════════════════════ -->

  <!-- From North (Achimota Forest Rd — Nsawam direction) -->
  <route id="route_NS" edges="ACH_N2J ACH_J2S"/>   <!-- Nsawam → CBD (straight) -->
  <route id="route_NE" edges="ACH_N2J AGG_J2E"/>   <!-- Nsawam → Aggrey St (right turn) -->
  <route id="route_NW" edges="ACH_N2J GUG_J2W"/>   <!-- Nsawam → Guggisberg (left turn) -->

  <!-- From South (Achimota Forest Rd — CBD direction) -->
  <route id="route_SN" edges="ACH_S2J ACH_J2N"/>   <!-- CBD → Nsawam (straight) -->
  <route id="route_SE" edges="ACH_S2J AGG_J2E"/>   <!-- CBD → Aggrey St (left turn) -->
  <route id="route_SW" edges="ACH_S2J GUG_J2W"/>   <!-- CBD → Guggisberg (right turn) -->

  <!-- From East (Aggrey Street) -->
  <route id="route_EW" edges="AGG_E2J GUG_J2W"/>   <!-- Aggrey → Guggisberg (straight) -->
  <route id="route_EN" edges="AGG_E2J ACH_J2N"/>   <!-- Aggrey → Nsawam (right turn) -->
  <route id="route_ES" edges="AGG_E2J ACH_J2S"/>   <!-- Aggrey → CBD (left turn) -->

  <!-- From West (Guggisberg Street) -->
  <route id="route_WE" edges="GUG_W2J AGG_J2E"/>   <!-- Guggisberg → Aggrey (straight) -->
  <route id="route_WN" edges="GUG_W2J ACH_J2N"/>   <!-- Guggisberg → Nsawam (right turn) -->
  <route id="route_WS" edges="GUG_W2J ACH_J2S"/>   <!-- Guggisberg → CBD (left turn) -->


  <!-- ═══════════════════════════════════════════════════════════════
       TRAFFIC FLOWS — Morning Rush 07:00-09:00 AM (t=0 to t=7200s)

       N/S (Achimota Forest Rd) is the primary N6 trunk — heaviest flow.
       E (Aggrey St) is a busy secondary road — moderate flow, 2 lanes.
       W (Guggisberg St) is a minor residential feeder — light flow, 2 lanes.
  ═══════════════════════════════════════════════════════════════ -->

  <!-- ── Achimota Forest Rd: Nsawam → CBD (HEAVIEST — inbound commuters) ── -->
  <flow id="flow_NS"   type="car"    route="route_NS"
        begin="0" end="7200" vehsPerHour="820"
        departLane="best" departSpeed="max"/>
  <flow id="flow_NS_t" type="trotro" route="route_NS"
        begin="0" end="7200" vehsPerHour="80"
        departLane="best" departSpeed="max"/>

  <!-- ── Achimota Forest Rd: CBD → Nsawam (lighter reverse flow) ────────── -->
  <flow id="flow_SN"   type="car"    route="route_SN"
        begin="0" end="7200" vehsPerHour="250"
        departLane="best" departSpeed="max"/>
  <flow id="flow_SN_t" type="trotro" route="route_SN"
        begin="0" end="7200" vehsPerHour="50"
        departLane="best" departSpeed="max"/>

  <!-- ── N/S turning movements ──────────────────────────────────────────── -->
  <flow id="flow_NE" type="car" route="route_NE"
        begin="0" end="7200" vehsPerHour="130"
        departLane="best" departSpeed="max"/>
  <flow id="flow_NW" type="car" route="route_NW"
        begin="0" end="7200" vehsPerHour="90"
        departLane="best" departSpeed="max"/>
  <flow id="flow_SE" type="car" route="route_SE"
        begin="0" end="7200" vehsPerHour="120"
        departLane="best" departSpeed="max"/>
  <flow id="flow_SW" type="car" route="route_SW"
        begin="0" end="7200" vehsPerHour="200"
        departLane="best" departSpeed="max"/>

  <!-- ── Aggrey Street: East → (moderate secondary road, now 2-lane) ────── -->
  <flow id="flow_EW" type="car" route="route_EW"
        begin="0" end="7200" vehsPerHour="280"
        departLane="best" departSpeed="max"/>
  <flow id="flow_EW_t" type="trotro" route="route_EW"
        begin="0" end="7200" vehsPerHour="40"
        departLane="best" departSpeed="max"/>
  <flow id="flow_EN" type="car" route="route_EN"
        begin="0" end="7200" vehsPerHour="180"
        departLane="best" departSpeed="max"/>
  <flow id="flow_ES" type="car" route="route_ES"
        begin="0" end="7200" vehsPerHour="100"
        departLane="best" departSpeed="max"/>

  <!-- ── Guggisberg Street: West → (minor residential feeder, 1-lane) ───── -->
  <flow id="flow_WE" type="car" route="route_WE"
        begin="0" end="7200" vehsPerHour="100"
        departLane="best" departSpeed="max"/>
  <flow id="flow_WN" type="car" route="route_WN"
        begin="0" end="7200" vehsPerHour="150"
        departLane="best" departSpeed="max"/>
  <flow id="flow_WS" type="car" route="route_WS"
        begin="0" end="7200" vehsPerHour="50"
        departLane="best" departSpeed="max"/>


  <!-- ═══════════════════════════════════════════════════════════════
       EMERGENCY VEHICLES — Deployed manually from Godot UI
       (No auto-spawned ambulances — click "Deploy Ambulance" button)
  ═══════════════════════════════════════════════════════════════ -->


  <!-- ═══════════════════════════════════════════════════════════════
       PEDESTRIAN FLOWS — Crossing at Junction

       Pedestrians walk from one side of each road arm to the other,
       using the pedestrian crossings at junction J0.
       Flow rates calibrated to morning rush at Achimota junction.

       N/S arm crossings (N6 trunk road): ~120 ped/hr total
       E arm crossing (Aggrey St): ~72 ped/hr total
       W arm crossing (Guggisberg St): ~50 ped/hr total
       (Reduced from original ~600 → ~362 ped/hr — calibrated to observed)
  ═══════════════════════════════════════════════════════════════ -->

  <!-- Crossing N arm (east↔west across Achimota Forest Rd, north side) -->
  <personFlow id="ped_cross_N_e2w" type="ped_fast" begin="0" end="7200" perHour="60">
    <walk from="ACH_N2J" to="ACH_J2N"/>
  </personFlow>
  <personFlow id="ped_cross_N_w2e" type="ped_fast" begin="0" end="7200" perHour="60">
    <walk from="ACH_J2N" to="ACH_N2J"/>
  </personFlow>

  <!-- Crossing S arm (east↔west across Achimota Forest Rd, south side) -->
  <personFlow id="ped_cross_S_e2w" type="ped_fast" begin="0" end="7200" perHour="60">
    <walk from="ACH_S2J" to="ACH_J2S"/>
  </personFlow>
  <personFlow id="ped_cross_S_w2e" type="ped_fast" begin="0" end="7200" perHour="60">
    <walk from="ACH_J2S" to="ACH_S2J"/>
  </personFlow>

  <!-- Crossing E arm (north↔south across Aggrey St, east side) -->
  <personFlow id="ped_cross_E_n2s" type="ped_fast" begin="0" end="7200" perHour="36">
    <walk from="AGG_E2J" to="AGG_J2E"/>
  </personFlow>
  <personFlow id="ped_cross_E_s2n" type="ped_fast" begin="0" end="7200" perHour="36">
    <walk from="AGG_J2E" to="AGG_E2J"/>
  </personFlow>

  <!-- Crossing W arm (north↔south across Guggisberg St, west side) -->
  <personFlow id="ped_cross_W_n2s" type="ped_fast" begin="0" end="7200" perHour="25">
    <walk from="GUG_W2J" to="GUG_J2W"/>
  </personFlow>
  <personFlow id="ped_cross_W_s2n" type="ped_fast" begin="0" end="7200" perHour="25">
    <walk from="GUG_J2W" to="GUG_W2J"/>
  </personFlow>

</routes>
