<!--
  ATCS-GH | Achimota/Neoplan Junction — Node Definitions
  ══════════════════════════════════════════════════════
  Real-world calibration: Achimota/Neoplan Junction, N6 Nsawam Road, Accra
  GPS: 5.6216 N, 0.2193 W

  Junction layout (local metre coordinates, origin at junction centre):
    J0 — central signalised junction (Achimota/Neoplan)
    N  — Achimota Forest Rd toward Nsawam (1500m north)
    S  — Achimota Forest Rd toward Accra CBD (1500m south)
    E  — Aggrey Street eastbound (1500m east)
    W  — Guggisberg Street westbound (1500m west)

  Coordinate system: metres, origin at junction centre.
  These files are fed to `netconvert` by scripts/build_network.py
  to produce simulation/intersection.net.xml.
-->
<nodes>
    <!-- Central junction: traffic-light type triggers auto TL generation -->
    <node id="J0" x="0"    y="0"    type="traffic_light"/>

    <!-- Arm endpoints — "priority" lets the junction manage right-of-way -->
    <node id="N"  x="0"     y="1500"  type="priority"/>
    <node id="S"  x="0"     y="-1500" type="priority"/>
    <node id="E"  x="1500"  y="0"     type="priority"/>
    <node id="W"  x="-1500" y="0"     type="priority"/>
</nodes>
